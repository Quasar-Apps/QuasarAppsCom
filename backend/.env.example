# Backend environment variables — copy to backend/.env and fill in.
# (.env is gitignored; this example is safe to commit.)

# --- MongoDB (required) ---
# The server fails to start if these are unset.
MONGO_URL=mongodb://localhost:27017
DB_NAME=quasarapps

# --- Resend email (contact-form notifications) ---
# If RESEND_API_KEY is empty, the contact form still works (messages are stored);
# the email notification is just skipped.
RESEND_API_KEY=
CONTACT_EMAIL=admin@quasarapps.com

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Defaults to "*". With credentialed CORS disabled (allow_credentials=False) a
# wildcard does NOT expose authenticated/cookie data — but it still lets any
# website make cross-origin requests to this API, and CORS is NOT an auth or
# security boundary. For production, pin to your real frontend origin(s):
#   CORS_ORIGINS=https://quasarapps.com,https://www.quasarapps.com
CORS_ORIGINS=*
