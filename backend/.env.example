# Backend environment variables — copy to backend/.env and fill in.
# (.env is gitignored; this example is safe to commit.)

# --- MongoDB (required) ---
# The server fails to start if these are unset.
MONGO_URL=mongodb://localhost:27017
DB_NAME=quasarapps

# --- Resend email (contact-form notifications) ---
# If RESEND_API_KEY is empty, the contact form still works (messages are stored);
# the email notification is just skipped.
RESEND_API_KEY=
CONTACT_EMAIL=admin@quasarapps.com

# --- CORS ---
# Comma-separated list of allowed frontend origins. Defaults to "*", which is
# safe now that credentialed CORS is disabled. Set this to your production
# frontend origin(s) to lock it down, e.g.:
#   CORS_ORIGINS=https://quasarapps.com,https://www.quasarapps.com
CORS_ORIGINS=*
